@model HomeViewModel
@{
    Layout = "_HomeLayout";
    ViewData["Title"] = "الصفحة الرئيسية";
}
<div class="container">
    @* الصف العلوي: يسار = صورة الكنيسة | وسط = الانبا مرقوريوس | يمين = البابا تواضروس *@
    <div class="home-hero mb-5">
        <div class="row g-3 g-md-4 align-items-end text-center">
            <div class="col-4 order-3 order-md-3">
                <div class="home-hero-item">
                    <div class="home-hero-figure home-hero-figure--portrait position-relative">
                        <img src="~/images/anba_marqorious.png" alt="الانبا مرقوريوس" class="w-100 h-100 object-fit-cover" onerror="this.style.display='none'; this.parentElement.querySelector('.img-fallback').classList.remove('d-none');" />
                        <div class="img-fallback d-none w-100 h-100 d-flex align-items-center justify-content-center text-muted position-absolute top-0 start-0">
                            <i class="bi bi-person-badge fs-1"></i>
                        </div>
                    </div>
                    <h2 class="home-hero-title d-none d-md-block">الانبا مرقوريوس</h2>
                </div>
            </div>
            <div class="col-4 order-2 order-md-2">
                <div class="home-hero-item home-hero-item--main">
                    <div class="home-hero-figure home-hero-figure--landscape position-relative">
                        <img src="~/images/church.png" alt="كنيسة مارمينا العجايبي" class="w-100 h-100 object-fit-cover" onerror="this.style.display='none'; this.parentElement.querySelector('.img-fallback').classList.remove('d-none');" />
                        <div class="img-fallback d-none w-100 h-100 d-flex align-items-center justify-content-center text-muted position-absolute top-0 start-0">
                            <i class="bi bi-building fs-1"></i>
                        </div>
                    </div>
                    <h2 class="home-hero-title home-hero-title--main d-none d-md-block">كنيسة مارمينا العجايبي</h2>
                </div>
            </div>
            
            <div class="col-4 order-1 order-md-1">
                <div class="home-hero-item">
                    <div class="home-hero-figure home-hero-figure--portrait position-relative">
                        <img src="~/images/pope_tawadros.png" alt="البابا تواضروس" class="w-100 h-100 object-fit-cover" onerror="this.style.display='none'; this.parentElement.querySelector('.img-fallback').classList.remove('d-none');" />
                        <div class="img-fallback d-none w-100 h-100 d-flex align-items-center justify-content-center text-muted position-absolute top-0 start-0">
                            <i class="bi bi-person-video2 fs-1"></i>
                        </div>
                    </div>
                    <h2 class="home-hero-title d-none d-md-block">البابا تواضروس</h2>
                </div>
            </div>
        </div>
    </div>

    @* المربع الأول: تأسيس الكنيسة وتدشينها + صورة الكنيسة *@
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="app-card animate__animated animate__fadeInUp p-4">
                <div class="row align-items-start g-3">
                    <div class="col-12 col-md-4 text-center">
                        <div class="home-story-image rounded overflow-hidden">
                            <img src="~/images/church.png" alt="كنيسة مارمينا العجايبي" class="w-100 rounded object-fit-cover" onerror="this.style.display='none';" />
                        </div>
                    </div>
                    <div class="col-12 col-md-8">
                        <h3 class="h6 text-muted mb-2">تأسيس الكنيسة وتدشينها</h3>
                        <p class="mb-0 app-preline">@Model.Box1Text</p>
                    </div>
                </div>
            </div>
        </div>
        @* المربع الثاني: ظهور صورة مارمينا على الستر + صورة الستر *@
        <div class="col-12">
            <div class="app-card animate__animated animate__fadeInUp p-4">
                <div class="row align-items-start g-3">
                    <div class="col-12 col-md-8">
                        <h3 class="h6 text-muted mb-2">في أثناء القداس الإلهي</h3>
                        <p class="mb-0 app-preline">@Model.Box2Text</p>
                    </div>
                    <div class="col-12 col-md-4 text-center">
                        <div class="home-story-image rounded overflow-hidden">
                            <img src="~/images/ster_mar_mina.png" alt="صورة القديس مارمينا على الستر" class="w-100 rounded object-fit-cover" onerror="this.style.display='none';" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* الردود على الشكاوى والمقترحات (عامة) *@
    @if (Model.ComplaintsWithReplies?.Count > 0)
    {
        <div class="row g-4 mb-4">
            <div class="col-12">
                <div class="app-card animate__animated animate__fadeInUp">
                    <div class="app-card-header">
                        <h2 class="h6 mb-0">
                            <i class="bi bi-reply me-2"></i>
                            الردود على الشكاوى والمقترحات
                        </h2>
                    </div>
                    <div class="p-4">
                        @foreach (var item in Model.ComplaintsWithReplies)
                        {
                            <div class="border border-secondary rounded p-3 mb-3 bg-light bg-opacity-50">
                                <p class="mb-2"><strong>الشكوى/المقترح:</strong></p>
                                <p class="mb-3 text-muted small app-preline">@item.Text</p>
                                <p class="mb-1"><strong>رد الإدارة:</strong></p>
                                <p class="mb-2 app-preline">@item.Reply</p>
                                <small class="text-muted">@item.RepliedAt.ToString("yyyy-MM-dd HH:mm")</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @* شكاوى ومقترحات *@
    <div class="row">
        <div class="col-12">
            <div class="app-card animate__animated animate__fadeInUp">
                <div class="app-card-header">
                    <h2 class="h6 mb-0">
                        <i class="bi bi-chat-left-text me-2"></i>
                        شكاوى ومقترحات
                    </h2>
                </div>
                <form asp-action="SubmitComplaint" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="complaintText" class="form-label">اكتب شكواك أو مقترحك هنا</label>
                        <textarea name="complaintText" id="complaintText" class="form-control" rows="4" placeholder="شكاوى أو مقترحات..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary app-btn">
                        <i class="bi bi-send"></i>
                        إرسال
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
