@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "غير مصرح";
}

<div class="app-card app-auth-card text-center animate__animated animate__fadeInUp">
    <div class="app-card-header justify-content-center">
        <i class="bi bi-shield-exclamation text-danger fs-1"></i>
    </div>
    <h1 class="h4 mb-2">غير مصرح بالدخول</h1>
    <p class="text-muted">ليس لديك صلاحية للوصول إلى هذه الصفحة.</p>
    <a asp-controller="Account" asp-action="Login" class="btn btn-primary app-btn">
        <i class="bi bi-arrow-right-circle"></i>
        العودة لتسجيل الدخول
    </a>
</div>
