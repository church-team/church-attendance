@model IEnumerable<churchAttendace.Models.Entities.Class>
@{
    ViewData["Title"] = "الفصول";
    ViewData["PageTitle"] = "إدارة الفصول";
    ViewData["PageSubtitle"] = "تنظيم الفصول وربطها بالمراحل";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new() { Title = "لوحة التحكم", Url = Url.Action("Index", "Dashboard", new { area = "Admin" }) },
        new() { Title = "الفصول", IsActive = true }
    };
}

<div class="app-card animate__animated animate__fadeInUp mb-3">
    <div class="app-card-header">
        <h2 class="h6 mb-0 d-none d-md-block">بحث في الفصول</h2>
        <h2 class="h6 mb-0 d-md-none">بحث</h2>
        <a class="btn btn-primary app-btn" asp-action="Create">
            <i class="bi bi-plus-circle"></i>
            إضافة فصل
        </a>
    </div>
    <form method="get" class="row g-2 align-items-end">
        <div class="col-12 col-md-6">
            <label class="form-label d-none d-md-block small">بحث</label>
            <input name="search" value="@ViewData["Search"]" class="form-control form-control-sm" placeholder="اسم الفصل" />
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label d-none d-md-block small">المرحلة</label>
            <select name="stageId" class="form-select form-select-sm">
                <option value="">كل المراحل</option>
                @if (ViewData["Stages"] is SelectList stages)
                {
                    foreach (var option in stages)
                    {
                        <option value="@option.Value" selected="@(option.Value == (ViewData["StageId"]?.ToString() ?? string.Empty))">@option.Text</option>
                    }
                }
            </select>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-outline-primary app-btn btn-sm">
                <i class="bi bi-filter"></i>
                تصفية
            </button>
        </div>
    </form>
</div>

<div class="app-card animate__animated animate__fadeInUp">
    <div class="table-responsive">
        <table class="table app-table app-table-mobile-ready align-middle">
            <thead>
                <tr>
                    <th>اسم الفصل</th>
                    <th>المرحلة</th>
                    <th>الحالة</th>
                    <th class="text-end">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">لا توجد فصول مسجلة حتى الآن.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td data-label="اسم الفصل">
                                <div class="d-flex align-items-start justify-content-between gap-2">
                                    <span class="flex-grow-1">@item.Name</span>
                                    <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary") d-md-none">@item.Stage?.Name</span>
                                </div>
                            </td>
                            <td data-label="المرحلة" class="d-none d-md-table-cell">@item.Stage?.Name</td>
                            <td data-label="الحالة">
                                <span class="badge @(item.IsActive ? "bg-success-subtle text-success" : "bg-secondary-subtle text-muted")">
                                    @(item.IsActive ? "نشط" : "غير نشط")
                                </span>
                            </td>
                            <td data-label="">
                                <div class="d-flex justify-content-end gap-2">
                                    <a class="btn btn-outline-secondary btn-sm" asp-action="Details" asp-route-id="@item.Id" title="عرض">
                                        <i class="bi bi-eye"></i>
                                        <span class="ms-1">عرض</span>
                                    </a>
                                    <a class="btn btn-outline-primary btn-sm" asp-action="Edit" asp-route-id="@item.Id" title="تعديل">
                                        <i class="bi bi-pencil"></i>
                                        <span class="ms-1">تعديل</span>
                                    </a>
                                    <form asp-action="Deactivate" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm" title="تعطيل">
                                            <i class="bi bi-x-circle"></i>
                                            <span class="ms-1">تعطيل</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
