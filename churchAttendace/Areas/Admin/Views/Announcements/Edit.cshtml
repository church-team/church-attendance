@model churchAttendace.Models.Entities.Announcement
@{
    ViewData["Title"] = "تعديل اعلان";
    ViewData["PageTitle"] = "تعديل الإعلان";
    ViewData["PageSubtitle"] = "تحديث عنوان ومحتوى الإعلان";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new() { Title = "لوحة التحكم", Url = Url.Action("Index", "Dashboard", new { area = "Admin" }) },
        new() { Title = "الاعلانات", Url = Url.Action("Index") },
        new() { Title = "تعديل", IsActive = true }
    };
}

<div class="app-card animate__animated animate__fadeInUp">
    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />
        <div class="row g-3">
            <div class="col-12">
                <label asp-for="Title" class="form-label">عنوان الإعلان</label>
                <input asp-for="Title" class="form-control" placeholder="عنوان الإعلان" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Body" class="form-label">محتوى الإعلان</label>
                <textarea asp-for="Body" class="form-control" rows="6" placeholder="اكتب نص الإعلان هنا"></textarea>
                <span asp-validation-for="Body" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">الإعلان نشط (يظهر للزوار)</label>
                </div>
            </div>
        </div>
        <div class="mt-4 d-flex gap-2 flex-wrap">
            <button type="submit" class="btn btn-primary app-btn">
                <i class="bi bi-check-circle"></i>
                حفظ
            </button>
            <a class="btn btn-outline-secondary app-btn" asp-action="Index">
                <i class="bi bi-x-circle"></i>
                إلغاء
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
