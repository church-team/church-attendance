@model IEnumerable<churchAttendace.Models.Entities.Session>
@{
    ViewData["Title"] = "الجلسات";
    ViewData["PageTitle"] = "إدارة الجلسات";
    ViewData["PageSubtitle"] = "متابعة جلسات الفصول وتواريخها";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new() { Title = "لوحة التحكم", Url = Url.Action("Index", "Dashboard", new { area = "Admin" }) },
        new() { Title = "الجلسات", IsActive = true }
    };
}

<div class="app-card animate__animated animate__fadeInUp mb-3">
    <div class="app-card-header">
        <h2 class="h6 mb-0 d-none d-md-block">فلترة الجلسات</h2>
        <h2 class="h6 mb-0 d-md-none">بحث</h2>
        <a class="btn btn-primary app-btn" asp-action="Create">
            <i class="bi bi-plus-circle"></i>
            إضافة جلسة
        </a>
    </div>
    <form method="get" class="row g-2 align-items-end">
        <div class="col-12 col-md-6">
            <label class="form-label d-none d-md-block small">الفصل</label>
            <select name="classId" class="form-select form-select-sm">
                <option value="">كل الفصول</option>
                @if (ViewData["Classes"] is SelectList classes)
                {
                    foreach (var option in classes)
                    {
                        <option value="@option.Value" selected="@(option.Value == (ViewData["ClassId"]?.ToString() ?? string.Empty))">@option.Text</option>
                    }
                }
            </select>
        </div>
        <div class="col-6 col-md-3">
            <label class="form-label d-none d-md-block small">من</label>
            <input type="date" name="from" value="@ViewData["From"]" class="form-control form-control-sm" />
        </div>
        <div class="col-6 col-md-3">
            <label class="form-label d-none d-md-block small">إلى</label>
            <input type="date" name="to" value="@ViewData["To"]" class="form-control form-control-sm" />
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-outline-primary app-btn btn-sm">
                <i class="bi bi-filter"></i>
                تصفية
            </button>
        </div>
    </form>
</div>

<div class="app-card animate__animated animate__fadeInUp">
    <div class="table-responsive">
        <table class="table app-table app-table-mobile-ready align-middle">
            <thead>
                <tr>
                    <th>اسم الدرس</th>
                    <th>الفصل</th>
                    <th>التاريخ</th>
                    <th>ملاحظات</th>
                    <th class="text-end">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">لا توجد جلسات حالياً.</td>
                    </tr>
                }
                else
                {
                    foreach (var session in Model)
                    {
                        <tr>
                            <td data-label="اسم الدرس">
                                <div class="d-flex align-items-start justify-content-between gap-2">
                                    <span class="flex-grow-1">@session.SessionName</span>
                                    <span class="badge bg-primary d-md-none">@session.Class?.Name</span>
                                </div>
                            </td>
                            <td data-label="الفصل" class="d-none d-md-table-cell">@session.Class?.Name</td>
                            <td data-label="التاريخ">@session.SessionDate.ToString("yyyy/MM/dd")</td>
                            <td data-label="ملاحظات">@session.Notes</td>
                            <td data-label="">
                                <div class="d-flex justify-content-end gap-2">
                                    <a class="btn btn-outline-secondary btn-sm" asp-action="Details" asp-route-id="@session.Id" title="عرض">
                                        <i class="bi bi-eye"></i>
                                        <span class="ms-1">عرض</span>
                                    </a>
                                    <a class="btn btn-outline-primary btn-sm" asp-action="Edit" asp-route-id="@session.Id" title="تعديل">
                                        <i class="bi bi-pencil"></i>
                                        <span class="ms-1">تعديل</span>
                                    </a>
                                    <form asp-action="Deactivate" asp-route-id="@session.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm" title="تعطيل">
                                            <i class="bi bi-x-circle"></i>
                                            <span class="ms-1">تعطيل</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
