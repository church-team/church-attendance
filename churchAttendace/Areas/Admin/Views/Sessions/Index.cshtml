@model IEnumerable<churchAttendace.Models.Entities.Session>
@{
    ViewData["Title"] = "الجلسات";
    ViewData["PageTitle"] = "إدارة الجلسات";
    ViewData["PageSubtitle"] = "متابعة جلسات الفصول وتواريخها";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new() { Title = "لوحة التحكم", Url = Url.Action("Index", "Dashboard", new { area = "Admin" }) },
        new() { Title = "الجلسات", IsActive = true }
    };
}

<div class="app-card animate__animated animate__fadeInUp mb-4">
    <div class="app-card-header">
        <div>
            <h2 class="h6 mb-1">فلترة الجلسات</h2>
            <div class="text-muted small">اختر الفصل أو الفترة الزمنية</div>
        </div>
        <a class="btn btn-primary app-btn" asp-action="Create">
            <i class="bi bi-plus-circle"></i>
            إضافة جلسة
        </a>
    </div>
    <form method="get" class="row g-2 align-items-end">
        <div class="col-12 col-md-6 col-lg-4">
            <label class="form-label">الفصل</label>
            <select name="classId" class="form-select">
                <option value="">كل الفصول</option>
                @if (ViewData["Classes"] is SelectList classes)
                {
                    foreach (var option in classes)
                    {
                        <option value="@option.Value" selected="@(option.Value == (ViewData["ClassId"]?.ToString() ?? string.Empty))">@option.Text</option>
                    }
                }
            </select>
        </div>
        <div class="col-6 col-md-3">
            <label class="form-label">من</label>
            <input type="date" name="from" value="@ViewData["From"]" class="form-control" />
        </div>
        <div class="col-6 col-md-3">
            <label class="form-label">إلى</label>
            <input type="date" name="to" value="@ViewData["To"]" class="form-control" />
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-outline-primary app-btn">
                <i class="bi bi-filter"></i>
                تصفية
            </button>
        </div>
    </form>
</div>

<div class="app-card animate__animated animate__fadeInUp">
    <div class="table-responsive">
        <table class="table app-table align-middle">
            <thead>
                <tr>
                    <th>اسم الجلسة</th>
                    <th>الفصل</th>
                    <th>التاريخ</th>
                    <th>ملاحظات</th>
                    <th class="text-end">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">لا توجد جلسات حالياً.</td>
                    </tr>
                }
                else
                {
                    foreach (var session in Model)
                    {
                        <tr>
                            <td>@session.SessionName</td>
                            <td>@session.Class?.Name</td>
                            <td>@session.SessionDate.ToString("yyyy/MM/dd")</td>
                            <td>@session.Notes</td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2 flex-wrap">
                                    <a class="btn btn-outline-secondary app-btn btn-sm" asp-action="Details" asp-route-id="@session.Id">
                                        <i class="bi bi-eye"></i>
                                        عرض
                                    </a>
                                    <a class="btn btn-outline-primary app-btn btn-sm" asp-action="Edit" asp-route-id="@session.Id">
                                        <i class="bi bi-pencil"></i>
                                        تعديل
                                    </a>
                                    <form asp-action="Deactivate" asp-route-id="@session.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-outline-danger app-btn btn-sm">
                                            <i class="bi bi-x-circle"></i>
                                            تعطيل
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
