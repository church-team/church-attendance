@model churchAttendace.Models.Entities.Session
@{
    ViewData["Title"] = "تفاصيل الجلسة";
    ViewData["PageTitle"] = "تفاصيل الجلسة";
    ViewData["PageSubtitle"] = "عرض بيانات الجلسة وسجل الحضور";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new() { Title = "لوحة التحكم", Url = Url.Action("Index", "Dashboard", new { area = "Admin" }) },
        new() { Title = "الجلسات", Url = Url.Action("Index") },
        new() { Title = "تفاصيل", IsActive = true }
    };
}

<div class="app-card animate__animated animate__fadeInUp mb-4">
    <div class="app-card-header">
        <div>
            <h2 class="h6 mb-1">@Model.SessionName</h2>
            <div class="text-muted small">@Model.Class?.Name - @Model.Class?.Stage?.Name</div>
        </div>
        <span class="badge @(Model.IsActive ? "bg-success-subtle text-success" : "bg-secondary-subtle text-muted")">
            @(Model.IsActive ? "نشط" : "غير نشط")
        </span>
    </div>
    <div class="row g-3">
        <div class="col-12 col-md-4">
            <div class="text-muted small">تاريخ الجلسة</div>
            <div>@Model.SessionDate.ToString("yyyy/MM/dd")</div>
        </div>
        <div class="col-12 col-md-8">
            <div class="text-muted small">ملاحظات</div>
            <div>@(string.IsNullOrWhiteSpace(Model.Notes) ? "-" : Model.Notes)</div>
        </div>
    </div>
</div>

<div class="app-card animate__animated animate__fadeInUp">
    <div class="app-card-header">
        <h3 class="h6 mb-0">سجل الحضور</h3>
        <a class="btn btn-outline-primary app-btn btn-sm" asp-controller="Attendance" asp-action="Take" asp-route-id="@Model.Id">
            <i class="bi bi-clipboard-check"></i>
            تسجيل الحضور
        </a>
    </div>
    <div class="table-responsive">
        <table class="table app-table align-middle">
            <thead>
                <tr>
                    <th>الطفل</th>
                    <th>الحضور</th>
                    <th>ملاحظات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.AttendanceRecords.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted">لا يوجد سجل حضور لهذه الجلسة بعد.</td>
                    </tr>
                }
                else
                {
                    foreach (var record in Model.AttendanceRecords)
                    {
                        <tr>
                            <td>@record.Child?.FullName</td>
                            <td>
                                @if (record.IsPresent)
                                {
                                    <span class="badge-present">حاضر</span>
                                }
                                else
                                {
                                    <span class="badge-absent">غائب</span>
                                }
                            </td>
                            <td>@record.Notes</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-4">
    <a class="btn btn-outline-primary app-btn" asp-action="Edit" asp-route-id="@Model.Id">
        <i class="bi bi-pencil"></i>
        تعديل
    </a>
    <a class="btn btn-outline-secondary app-btn" asp-action="Index">
        <i class="bi bi-arrow-right-circle"></i>
        العودة
    </a>
</div>
