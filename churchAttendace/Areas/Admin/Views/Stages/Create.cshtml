@model churchAttendace.Models.Entities.Stage
@{
    ViewData["Title"] = "إضافة مرحلة";
    ViewData["PageTitle"] = "إضافة مرحلة جديدة";
    ViewData["PageSubtitle"] = "املأ البيانات المطلوبة لإضافة مرحلة";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new() { Title = "لوحة التحكم", Url = Url.Action("Index", "Dashboard", new { area = "Admin" }) },
        new() { Title = "المراحل", Url = Url.Action("Index") },
        new() { Title = "إضافة", IsActive = true }
    };
}

<div class="app-card animate__animated animate__fadeInUp">
    <form method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-12 col-lg-6">
                <label asp-for="Name" class="form-label">اسم المرحلة</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label">الوصف</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
        </div>
        <div class="mt-4 d-flex gap-2 flex-wrap">
            <button type="submit" class="btn btn-primary app-btn">
                <i class="bi bi-check-circle"></i>
                حفظ
            </button>
            <a class="btn btn-outline-secondary app-btn" asp-action="Index">
                <i class="bi bi-x-circle"></i>
                إلغاء
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
