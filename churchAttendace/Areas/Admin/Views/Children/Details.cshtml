@model churchAttendace.Models.Entities.Child
@{
    ViewData["Title"] = "تفاصيل الطفل";
    ViewData["PageTitle"] = "تفاصيل الطفل";
    ViewData["PageSubtitle"] = "عرض بيانات الطفل وولي الأمر";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new() { Title = "لوحة التحكم", Url = Url.Action("Index", "Dashboard", new { area = "Admin" }) },
        new() { Title = "الأطفال", Url = Url.Action("Index") },
        new() { Title = "تفاصيل", IsActive = true }
    };
}

<div class="app-card animate__animated animate__fadeInUp">
    <div class="app-card-header">
        <div>
            <h2 class="h6 mb-1">@Model.FullName</h2>
            <div class="text-muted small">@Model.Class?.Name - @Model.Class?.Stage?.Name</div>
        </div>
        <span class="badge @(Model.IsActive ? "bg-success-subtle text-success" : "bg-secondary-subtle text-muted")">
            @(Model.IsActive ? "نشط" : "غير نشط")
        </span>
    </div>
    <div class="row g-3">
        <div class="col-12 col-md-6">
            <div class="text-muted small">هاتف ولي الأمر</div>
            <div>@Model.ParentPhoneNumber</div>
        </div>
        <div class="col-12 col-md-6">
            <div class="text-muted small">هاتف الطفل</div>
            <div>@(Model.PhoneNumber ?? "-")</div>
        </div>
        <div class="col-12 col-md-6">
            <div class="text-muted small">تاريخ الميلاد</div>
            <div>@Model.BirthDate.ToString("yyyy/MM/dd")</div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a class="btn btn-outline-primary app-btn" asp-action="Edit" asp-route-id="@Model.Id">
        <i class="bi bi-pencil"></i>
        تعديل
    </a>
    <a class="btn btn-outline-secondary app-btn" asp-action="Index">
        <i class="bi bi-arrow-right-circle"></i>
        العودة
    </a>
</div>
